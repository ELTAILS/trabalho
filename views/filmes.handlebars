<main class="container">
    <h1 class="h1 text-center mb-5 mt-5">Confira nosso novos filmes </h1>
    
    <div style="display: grid; grid-template-columns: 33% 33% 33%;">
        {{#each filmes}} <!--titulo, diretor, lancamento, genero, descricao-->
        <div class="card mb-5 mt-5" style="width: 18rem;">
            <div class="card-body">
                <h5 class="card-title mb-3">{{titulo}}</h5>
                <p class="card-text">{{lancamento}}</p>
                <p class="card-text">{{genero}}</p>
                <p class="card-text">{{descricao}}</p>
                <div class="w-100 text-center"><a href="#" class="btn btn-primary">Assistir filme</a></div>
            </div>
        </div>
        {{/each}}
    </div>
</main>